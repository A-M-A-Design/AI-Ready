{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "welcome-ai-ready/component.schema.json",
  "title": "WDS AI-Ready Component Schema",
  "description": "JSON Schema for Welcome Design System AI-ready component documentation",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "component",
    "figma_ids",
    "intent",
    "anatomy",
    "composition",
    "props",
    "variant_diffs",
    "variant_logic",
    "rules",
    "relationships",
    "invalid_combinations",
    "context",
    "tokens",
    "metadata"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "welcome-ai-ready/component.schema.json",
      "description": "Reference to this schema"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of the schema format"
    },
    "component": {
      "type": "string",
      "description": "Human-readable component name (e.g., 'Button', 'Card')"
    },
    "figma_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Figma component IDs (e.g., 'web.button-bb', 'aem.billboard')"
    },
    "intent": {
      "type": "object",
      "required": ["description", "solves", "task_context", "use_when", "avoid_when"],
      "properties": {
        "description": {
          "type": "string",
          "description": "One-line purpose of the component"
        },
        "solves": {
          "type": "string",
          "description": "UX problem this component addresses"
        },
        "task_context": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Categories/contexts where component is applicable"
        },
        "use_when": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recommended usage scenarios"
        },
        "avoid_when": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Scenarios to avoid using this component"
        }
      }
    },
    "anatomy": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/anatomyElement"
      },
      "description": "Hierarchical structure of component elements"
    },
    "composition": {
      "type": "object",
      "required": ["requires", "allows", "forbids"],
      "properties": {
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Mandatory child components or elements"
        },
        "allows": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional child components or elements"
        },
        "forbids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Prohibited compositions"
        }
      }
    },
    "props": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/propDefinition"
      },
      "description": "Component properties (variants, booleans, text, instance swaps)"
    },
    "variant_diffs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/variantDiff"
      },
      "description": "Style changes per variant configuration vs. default"
    },
    "variant_logic": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "use_when": { "type": "string" }
          }
        }
      },
      "description": "Guidance on when to use each variant value"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "description": "Usage guidelines and best practices"
    },
    "relationships": {
      "type": "object",
      "required": ["related", "escalates_to", "degrades_to", "groups_with", "replaces"],
      "properties": {
        "related": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Related components"
        },
        "escalates_to": {
          "type": ["string", "null"],
          "description": "Component to use for more complex scenarios"
        },
        "degrades_to": {
          "type": ["string", "null"],
          "description": "Fallback component for simpler scenarios"
        },
        "groups_with": {
          "type": ["string", "array", "null"],
          "description": "Components commonly used together"
        },
        "replaces": {
          "type": ["string", "null"],
          "description": "Legacy component this replaces"
        }
      }
    },
    "invalid_combinations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Prop combinations that should not be used"
    },
    "context": {
      "type": "object",
      "required": ["modality"],
      "properties": {
        "modality": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["desktop", "tablet", "mobile"]
          },
          "description": "Supported device types"
        }
      }
    },
    "tokens": {
      "type": "object",
      "properties": {
        "border": {
          "type": "array",
          "items": { "type": "string" }
        },
        "typography": {
          "type": "array",
          "items": { "type": "string" }
        },
        "spacing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sizing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "color": {
          "type": "array",
          "items": { "type": "string" }
        },
        "other": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "description": "Design tokens used by the component, categorized"
    },
    "metadata": {
      "type": "object",
      "required": ["figma_source", "structural_source", "variant_count", "default_variant", "variant_diffs_count", "ai_content_source", "fusion_date", "pipeline_version"],
      "properties": {
        "figma_source": {
          "type": "object",
          "properties": {
            "nodeId": { "type": "string" },
            "pageId": { "type": "string" }
          }
        },
        "structural_source": {
          "type": "string",
          "description": "Extraction method (e.g., 'mcp_v6')"
        },
        "variant_count": {
          "type": "integer",
          "minimum": 1
        },
        "default_variant": {
          "type": "string",
          "description": "Default variant configuration"
        },
        "variant_diffs_count": {
          "type": "integer",
          "minimum": 0
        },
        "ai_content_source": {
          "type": "string",
          "description": "Source of AI/UX content (e.g., 'supernova')"
        },
        "fusion_date": {
          "type": "string",
          "format": "date-time"
        },
        "pipeline_version": {
          "type": "string"
        },
        "note": {
          "type": "string",
          "description": "Optional extraction notes"
        }
      }
    }
  },
  "$defs": {
    "anatomyElement": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["container", "instance", "text", "vector"],
          "description": "Element type"
        },
        "parent": {
          "type": "string",
          "description": "Parent element name"
        },
        "children": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Child element names"
        },
        "instanceOf": {
          "type": "string",
          "description": "For instances: the component being instantiated"
        },
        "styles": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          },
          "description": "Design token references or raw values"
        }
      }
    },
    "propDefinition": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "instance_swap"],
          "description": "Property type"
        },
        "default": {
          "description": "Default value"
        },
        "enum": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For string props: allowed values"
        },
        "binding": {
          "type": "object",
          "properties": {
            "element": { "type": "string" },
            "affects": {
              "type": "string",
              "enum": ["visible", "content", "mainComponent"]
            }
          },
          "description": "How this prop binds to an element"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "variantDiff": {
      "type": "object",
      "required": ["configuration", "changes"],
      "properties": {
        "configuration": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Variant axis values that trigger these changes"
        },
        "changes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          },
          "description": "Style changes per element (key=element name)"
        }
      }
    },
    "rule": {
      "type": "object",
      "required": ["rule", "description", "severity"],
      "properties": {
        "rule": {
          "type": "string",
          "description": "Rule title"
        },
        "description": {
          "type": "string",
          "description": "Detailed explanation"
        },
        "severity": {
          "type": "string",
          "enum": ["do", "dont", "caution"],
          "description": "Guideline type"
        }
      }
    }
  }
}